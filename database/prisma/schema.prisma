// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PROVIDER
  ADMIN
  SUPERADMIN
}

enum AccountStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum ProviderRequestStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

enum ProviderStatus {
  ACTIVE
  SUSPENDED
}

enum PostStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum ServiceStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum ReactionType {
  LIKE
  LOVE
  WOW
  HAHA
  SAD
  ANGRY
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  PROVIDER_REQUEST_APPROVED
  PROVIDER_REQUEST_REJECTED
  REPORT_STATUS
  TICKET_STATUS
  TICKET_REPLY
  SYSTEM
}

enum LogAction {
  USER_LOGIN
  USER_REGISTER
  POST_CREATED
  POST_DELETED
  PROVIDER_REQUEST_SUBMITTED
  PROVIDER_REQUEST_APPROVED
  PROVIDER_REQUEST_REJECTED
  USER_BLOCKED
  USER_UNBLOCKED
  REPORT_REVIEWED
  REPORT_CREATED
  SERVICE_CREATED
  SERVICE_DELETED
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_MESSAGE_CREATED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  ACCOUNT
  TECHNICAL
  REPORT
  PROVIDER
  OTHER
}

model User {
  id                 String        @id @default(uuid())
  firstName          String
  lastName           String
  username           String        @unique
  email              String        @unique
  password           String
  profilePicturePath String?
  bio                String?
  role               UserRole      @default(USER)
  accountStatus      AccountStatus @default(ACTIVE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  posts     Post[]
  comments  Comment[]
  reactions Reaction[]
  commentReactions CommentReaction[]

  providerRequests ProviderRequest[] @relation("ProviderRequestOwner")
  reviewedRequests ProviderRequest[] @relation("ProviderRequestReviewer")
  providerProfile  ProviderProfile?

  reportsCreated     Report[]       @relation("ReportCreator")
  reportsAgainstUser Report[]       @relation("ReportedUser")
  reportsReviewed    Report[]       @relation("ReportReviewer")
  notifications      Notification[]
  logs               Log[]
  reviews            Review[]
  savedPosts         SavedPost[]
  savedServices      SavedService[]

  following                Follow[]                  @relation("UserFollowing")
  followers                Follow[]                  @relation("UserFollowers")
  conversationParticipants ConversationParticipant[]
  messages                 Message[]
  supportTickets           SupportTicket[]           @relation("TicketCreator")
  assignedTickets          SupportTicket[]           @relation("TicketAssignee")
  relatedTickets           SupportTicket[]           @relation("TicketRelatedUser")
  ticketMessages           SupportTicketMessage[]    @relation("TicketMessageAuthor")
}

model Post {
  id        String     @id @default(uuid())
  content   String
  status    PostStatus @default(ACTIVE)
  authorId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images    PostImage[]
  comments  Comment[]
  reactions Reaction[]

  reports        Report[]
  savedBy        SavedPost[]
  supportTickets SupportTicket[] @relation("TicketPost")
}

model PostImage {
  id        String   @id @default(uuid())
  imagePath String
  postId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  status    CommentStatus @default(VISIBLE)
  postId    String
  userId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  reports        Report[]
  supportTickets SupportTicket[] @relation("TicketComment")
  reactions      CommentReaction[]

  @@index([parentId])
}

model Reaction {
  id        String       @id @default(uuid())
  type      ReactionType @default(LIKE)
  postId    String
  userId    String
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model ProviderRequest {
  id                      String                @id @default(uuid())
  userId                  String
  professionalName        String
  professionalDescription String
  phone                   String
  city                    String
  cinNumber               String
  cinPicturePath          String
  additionalInfo          String?
  status                  ProviderRequestStatus @default(PENDING)
  submittedAt             DateTime              @default(now())
  reviewedAt              DateTime?
  reviewedById            String?

  user       User  @relation("ProviderRequestOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ProviderRequestReviewer", fields: [reviewedById], references: [id])

  @@index([status])
}

model ProviderProfile {
  id                      String         @id @default(uuid())
  userId                  String         @unique
  professionalName        String
  professionalDescription String
  phone                   String
  city                    String
  providerStatus          ProviderStatus @default(ACTIVE)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  services Service[]
}

model Category {
  id          String        @id @default(uuid())
  name        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  subcategories Subcategory[]
  services      Service[]
}

model Subcategory {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

model Service {
  id                String        @id @default(uuid())
  providerProfileId String
  categoryId        String?
  subcategoryId     String?
  title             String
  description       String
  price             Decimal?
  city              String
  category          String
  subcategory       String?
  keywords          String[]      @default([])
  status            ServiceStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  categoryRef     Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryRef  Subcategory?    @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  images          ServiceImage[]
  reviews         Review[]
  reports         Report[]
  savedBy         SavedService[]
  supportTickets SupportTicket[] @relation("TicketService")

  @@index([categoryId])
  @@index([subcategoryId])
}

model CommentReaction {
  id        String       @id @default(uuid())
  type      ReactionType @default(LIKE)
  commentId String
  userId    String
  createdAt DateTime     @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model ServiceImage {
  id        String   @id @default(uuid())
  serviceId String
  imagePath String
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String?
  postId         String?
  commentId      String?
  serviceId      String?
  reason         String
  description    String?
  status         ReportStatus @default(PENDING)
  moderationNote String?
  actionTaken    String?
  createdAt      DateTime     @default(now())
  reviewedAt     DateTime?
  reviewedById   String?

  reporter     User     @relation("ReportCreator", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User?    @relation("ReportedUser", fields: [reportedUserId], references: [id])
  post         Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  reviewedBy   User?    @relation("ReportReviewer", fields: [reviewedById], references: [id])
  supportTickets SupportTicket[] @relation("TicketReport")
}

model SavedPost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

model SavedService {
  id        String   @id @default(uuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id               String         @id @default(uuid())
  userId           String
  assignedToId     String?
  relatedUserId    String?
  relatedPostId    String?
  relatedCommentId String?
  relatedServiceId String?
  relatedReportId  String?
  subject          String
  description      String
  category         TicketCategory @default(OTHER)
  status           TicketStatus   @default(OPEN)
  priority         TicketPriority @default(NORMAL)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  closedAt         DateTime?

  user           User     @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo     User?    @relation("TicketAssignee", fields: [assignedToId], references: [id])
  relatedUser    User?    @relation("TicketRelatedUser", fields: [relatedUserId], references: [id])
  relatedPost    Post?    @relation("TicketPost", fields: [relatedPostId], references: [id], onDelete: SetNull)
  relatedComment Comment? @relation("TicketComment", fields: [relatedCommentId], references: [id], onDelete: SetNull)
  relatedService Service? @relation("TicketService", fields: [relatedServiceId], references: [id], onDelete: SetNull)
  relatedReport  Report?  @relation("TicketReport", fields: [relatedReportId], references: [id], onDelete: SetNull)
  messages       SupportTicketMessage[]

  @@index([userId])
  @@index([assignedToId])
  @@index([status])
}

model SupportTicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  message   String
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation("TicketMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Log {
  id          String    @id @default(uuid())
  actorId     String?
  action      LogAction
  entityType  String
  entityId    String?
  description String?
  createdAt   DateTime  @default(now())

  actor User? @relation(fields: [actorId], references: [id])
}

model Review {
  id        String       @id @default(uuid())
  userId    String
  serviceId String
  rating    Int
  comment   String?
  status    ReviewStatus @default(VISIBLE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
}
